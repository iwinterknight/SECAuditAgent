# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# --- Secrets & local config ---
.env
.env.*
!.env.example

# --- Vector / structured stores (rebuildable from source) ---
qdrant_storage/
chroma/
.chroma/
*.duckdb
*.duckdb.wal

# --- Derived corpus artifacts (rebuilt by the ingestion pipeline) ---
# NOTE: raw source corpus under data/SEC/ — 10-K PDFs and the XBRL filing
# packages (data/SEC/10-K Filings/xbrl/) — is versioned via Git LFS. Do NOT
# ignore it; only the *derived* outputs below are rebuildable and ignored.
data/derived/
data/parsed/
data/index/

# --- Evaluation transient outputs (keep committed baselines under eval/baselines/) ---
eval/runs/
eval/_tmp/

# --- Educator Reports: Markdown is the committed source of truth; the rendered
# PDFs are rebuildable via reports/render.py, so they are ignored (§2, §5.2). ---
reports/**/*.pdf

# --- Observability local data ---
.phoenix/
langfuse_data/

# --- Logs ---
*.log
logs/

# --- Frontend (added in M9) ---
node_modules/
ui/dist/

# --- OS / IDE ---
.DS_Store
Thumbs.db
.idea/
.vscode/
